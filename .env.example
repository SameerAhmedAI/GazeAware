# GazeAware — Environment Variables Template
# Copy this file to .env and fill in your values.

# Anthropic Claude API Key (required for online NLP mode)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Optional: Override webcam index (default: 0)
# WEBCAM_INDEX=0

# Optional: Flask server port (default: 5050)
# FLASK_PORT=5050
